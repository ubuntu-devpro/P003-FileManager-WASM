@inject DialogService DialogService
@using FileManager.Shared.Models

<div style="padding:1rem; min-width: 320px;">
    <h4 style="margin:0 0 0.5rem;">✏️ 重新命名</h4>
    <RadzenTextBox @bind-Value="@newName" Placeholder="新名稱" Style="width:100%; margin-bottom: 1rem;" />
    <div style="display:flex; justify-content:flex-end; gap:0.5rem;">
        <RadzenButton Text="取消" Click="@(() => DialogService.Close(null))" ButtonStyle="ButtonStyle.Secondary" />
        <RadzenButton Text="確認" Click="@Confirm" ButtonStyle="ButtonStyle.Primary" />
    </div>
</div>

@code {
    [Parameter]
    public FileItem? Item { get; set; }

    private string newName = "";

    protected override void OnInitialized()
    {
        if (Item != null)
            newName = Item.Name;
    }

    private void Confirm()
    {
        if (!string.IsNullOrWhiteSpace(newName))
            DialogService.Close(newName);
    }
}
