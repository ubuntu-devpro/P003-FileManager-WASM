@page "/login"
@inject IAuthService Auth
@inject NavigationManager Nav

<PageTitle>登入 - 檔案管理器</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h1>📁 檔案管理器</h1>
        <h2>登入</h2>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-msg">@errorMessage</div>
        }

        <div class="form-group">
            <label>Email</label>
            <input type="email" @bind="email" placeholder="admin@devpro.com.tw" />
        </div>

        <div class="form-group">
            <label>密碼</label>
            <input type="password" @bind="password" placeholder="••••••" @onkeyup="OnKeyUp" />
        </div>

        <button class="login-btn" @onclick="DoLogin" disabled="@isLoading">
            @(isLoading ? "登入中..." : "登入")
        </button>

        <div class="hint">
            <p>測試帳號：</p>
            <p>• admin@devpro.com.tw / admin123（Admin）</p>
            <p>• johnny@sinopac.com / johnny123（一般使用者）</p>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? errorMessage;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        // If already logged in, go to home
        await Auth.CheckSessionAsync();
        if (Auth.State.IsAuthenticated)
            Nav.NavigateTo("/");
    }

    private async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "請輸入 Email 和密碼";
            return;
        }

        isLoading = true;
        errorMessage = null;

        var ok = await Auth.LoginAsync(email, password);

        isLoading = false;

        if (ok)
        {
            Nav.NavigateTo("/");
        }
        else
        {
            errorMessage = "帳號或密碼錯誤";
        }
    }

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await DoLogin();
    }
}

<style>
.login-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
}

.login-card {
    background: white;
    padding: 2rem 2.5rem;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    width: 360px;
    text-align: center;
}

.login-card h1 { font-size: 1.5rem; margin: 0 0 0.25rem; color: #1a1a2e; }
.login-card h2 { font-size: 1.1rem; color: #666; margin: 0 0 1.5rem; font-weight: normal; }

.form-group { margin-bottom: 1rem; text-align: left; }
.form-group label { display: block; font-size: 0.85rem; color: #555; margin-bottom: 0.25rem; }
.form-group input {
    width: 100%; padding: 0.6rem; border: 1px solid #ddd;
    border-radius: 6px; font-size: 1rem; box-sizing: border-box;
}
.form-group input:focus { outline: none; border-color: #4F81BD; }

.login-btn {
    width: 100%; padding: 0.75rem; background: #4F81BD;
    color: white; border: none; border-radius: 6px;
    font-size: 1rem; cursor: pointer; margin-top: 0.5rem;
}
.login-btn:hover { background: #3a6291; }
.login-btn:disabled { background: #ccc; cursor: not-allowed; }

.error-msg {
    background: #fdf2f2; color: #c0392b; padding: 0.75rem;
    border-radius: 6px; margin-bottom: 1rem; font-size: 0.9rem;
}

.hint {
    margin-top: 1.5rem; font-size: 0.78rem; color: #888;
    text-align: left; border-top: 1px solid #eee; padding-top: 1rem;
}
.hint p { margin: 0.25rem 0; }
</style>
